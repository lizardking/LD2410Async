# -----------------------------------------------------------------------------
# Arduino / C++ Library - .gitattributes
# -----------------------------------------------------------------------------
# This file defines how Git should treat files in this repository.
# Helps ensure consistent line endings, diffs, and packaging behavior.
# -----------------------------------------------------------------------------

# === General text handling ===
* text=auto eol=lf        # Normalize all text files to LF in the repo

# === Source code (force LF for consistency across platforms) ===
*.ino   text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.c     text eol=lf
*.hpp   text eol=lf

# === Scripts & configs (force LF) ===
*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf diff=markdown

# === Windows batch files (force CRLF) ===
*.bat   text eol=crlf
*.cmd   text eol=crlf

# === Binary files (no diffing) ===
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.ico   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.pdf   binary

# === Arduino library packaging ===
# Ignore development / CI files when exporting with `git archive`
.vs/*             export-ignore
.idea/*           export-ignore
*.code-workspace export-ignore
*.sln             export-ignore
*.vcxproj*        export-ignore
*.DS_Store        export-ignore
.gitignore        export-ignore
.gitattributes    export-ignore
.github/*         export-ignore

# === Git LFS (optional: uncomment if using LFS for large assets) ===
# *.psd filter=lfs diff=lfs merge=lfs -text
# *.bin filter=lfs diff=lfs merge=lfs -text